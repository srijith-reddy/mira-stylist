# ──────────────────────────────────────────────────────────────────────────────
# MIRA Stylist — Environment Variables
# Copy this file to `.env` and fill in your actual keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="MIRA Stylist"
DEBUG=false

# ── FASHN Virtual Try-On ─────────────────────────────────────────────────────
FASHN_API_KEY=your_fashn_api_key_here
FASHN_API_URL=https://api.fashn.ai/v1

# ── Kling AI ─────────────────────────────────────────────────────────────────
KLING_API_KEY=your_kling_api_key_here
KLING_API_URL=https://api.klingai.com/v1

# ── Anthropic (stylist commentary via Claude) ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (optional — voice TTS) ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=output/mira_stylist

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
